# Copy to .env and fill in values from the Supabase project dashboard.
# Only EXPO_PUBLIC_* vars are exposed to the app (via expo-constants).
# NEVER put the service-role key anywhere in this repo or app code.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
